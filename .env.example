# =============================================================================
# Newzyx V2 — Server edition | copy to .env and fill in (repo root).
# =============================================================================

# --- Hybrid / paths (optional) ---
# NEWZYX_EPHEMERAL=1          # 1=temp build dir (default); 0=write under ./website/
# NEWZYX_WORKSPACE=/path      # Fixed workspace; not deleted after upload
# NEWZYX_DB_PATH=/path/to/newzyx.db   # SQLite path (e.g. USB drive on Raspberry Pi)

# --- LLM (default: OpenAI) ---
LLM_TYPE=openai
OPENAI_API_KEY=your-openai-key
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Perplexity (only if LLM_TYPE is not openai)
PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions
PERPLEXITY_API_KEY=your-perplexity-key
PERPLEXITY_MODEL=sonar

# --- ElevenLabs TTS ---
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/text-to-dialogue
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_MODEL_ID_DIALOGUE=eleven_v3
ELEVENLABS_VOICE_ID=6yesjON9QKSLuPBdVCoB
ELEVENLABS_VOICE_ID2=IMcnLoWVvO9c3ycsIvkh

# --- AWS (S3 publish + optional CloudFront) ---
S3_BUCKET=kidsnewsfeed
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-2
# Public URL used in RSS enclosure links (CloudFront or S3 website endpoint)
WEBSITE_URL=https://kidsnewsfeed.s3.us-east-2.amazonaws.com
DISTRIBUTION_ID=your-cloudfront-distribution-id
